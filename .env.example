# Clé API Groq (gratuite sur https://console.groq.com/keys)
VITE_GROQ_API_KEY=gsk_xxxxx

# Vercel KV / Upstash Redis pour les sessions, profils et séances
# Vercel KV v3 attend KV_REST_API_URL / KV_REST_API_TOKEN.
# Les anciens noms UPSTASH_REDIS_REST_* sont aussi supportés.
KV_REST_API_URL=https://xxxx.upstash.io
KV_REST_API_TOKEN=xxxxx

# Strava OAuth (créer une app sur https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=193301
STRAVA_CLIENT_SECRET=ton_client_secret_ici

# Garmin Connect API (officiel - https://developerportal.garmin.com)
GARMIN_CLIENT_ID=ton_garmin_client_id
GARMIN_CLIENT_SECRET=ton_garmin_client_secret
